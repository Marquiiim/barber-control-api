generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model appointments {
  id               Int                       @id @default(autoincrement())
  name             String                    @db.VarChar(100)
  phone_number     String                    @db.VarChar(15)
  service_id       Int
  appointment_date DateTime                  @db.Date
  hour_id          Int
  type_payment     appointments_type_payment
  created_at       DateTime                  @default(now()) @db.Timestamp(0)
  services         services                  @relation(fields: [service_id], references: [id], onUpdate: Restrict, map: "appointments_ibfk_1")
  schedules        schedules                 @relation(fields: [hour_id], references: [id], onUpdate: Restrict, map: "appointments_ibfk_2")

  @@index([service_id], map: "service_id")
  @@index([hour_id], map: "time_id")
}

model schedules {
  id           Int            @id @default(autoincrement())
  availables   DateTime       @unique(map: "availables") @db.Time(0)
  appointments appointments[]
}

model services {
  id           Int            @id @default(autoincrement())
  availables   String         @db.VarChar(100)
  price        Decimal        @db.Decimal(10, 2)
  description  String?        @db.Text
  appointments appointments[]
}

enum appointments_type_payment {
  pix
  d_bito   @map("débito")
  cr_dito  @map("crédito")
  dinheiro
}
